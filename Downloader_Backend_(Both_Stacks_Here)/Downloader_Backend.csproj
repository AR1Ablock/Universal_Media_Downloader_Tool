<Project Sdk="Microsoft.NET.Sdk.Web">

  <ItemGroup>
  <None Update="app_icon\favicon.ico">
    <Pack>false</Pack>
    <CopyToOutputDirectory>Always</CopyToOutputDirectory>
  </None>
  </ItemGroup>

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <InvariantGlobalization>false</InvariantGlobalization>
    <OutputType>WinExe</OutputType>   <!-- ← This line hides the console -->
    <!-- Allow unsafe code required by LibraryImportGenerator and some interop calls -->
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- icon will only show in windows build -->
    <ApplicationIcon>app_icon\favicon.ico</ApplicationIcon>
  </PropertyGroup>


  <ItemGroup>
    <!-- Use resolved compatible Serilog versions to avoid NU1603 warnings -->
    <PackageReference Include="Serilog" Version="4.0.0" />
    <PackageReference Include="Serilog.Sinks.Console" Version="6.0.0" />
    <PackageReference Include="Serilog.Sinks.File" Version="6.0.0" />
    <PackageReference Include="Serilog.AspNetCore" Version="7.0.0" />
    <PackageReference Include="Spectre.Console" Version="0.54.0" />
    <!-- System.Management provides Management classes on Windows when used; include to satisfy references -->
    <PackageReference Include="System.Management" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="8.0.0" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.0" />
  </ItemGroup>


<!-- 1️⃣ When -r is provided (publish or build with runtime) -->
<ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64'">
  <Content Include="tools/windows/x64/yt_dlp_win_x64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/ffmpeg_win_x64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/deno_win_x64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/node_win_x64.exe" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-arm64'">
  <Content Include="tools/windows/arm64/yt_dlp_win_arm64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/arm64/ffmpeg_win_arm64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/arm64/deno_win_arm64.exe" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/windows/arm64/node_win_arm64.exe" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-x64'">
  <Content Include="tools/linux/x64/yt_dlp_linux_x64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/ffmpeg_linux_x64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/deno_linux_x64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/node_linux_x64" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-arm64'">
  <Content Include="tools/linux/arm64/yt_dlp_linux_arm64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/arm64/ffmpeg_linux_arm64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/arm64/deno_linux_arm64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/linux/arm64/node_linux_arm64" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == 'osx-x64'">
  <Content Include="tools/mac/yt_dlp_mac_universal" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/ffmpeg_mac_universal" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/x64/deno_mac_x64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/x64/node_mac_x64" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == 'osx-arm64'">
  <Content Include="tools/mac/yt_dlp_mac_universal" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/ffmpeg_mac_universal" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/arm64/deno_mac_arm64" CopyToPublishDirectory="PreserveNewest" />
  <Content Include="tools/mac/arm64/node_mac_arm64" CopyToPublishDirectory="PreserveNewest" />
</ItemGroup>


<!-- 2️⃣ Fallback: No -r provided (normal build / debug / run) -->
<ItemGroup Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('Windows'))">
  <Content Include="tools/windows/x64/yt_dlp_win_x64.exe" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/ffmpeg_win_x64.exe" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/deno_win_x64.exe" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/windows/x64/node_win_x64.exe" CopyToOutputDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('Linux'))">
  <Content Include="tools/linux/x64/yt_dlp_linux_x64" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/ffmpeg_linux_x64" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/deno_linux_x64" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/linux/x64/node_linux_x64" CopyToOutputDirectory="PreserveNewest" />
</ItemGroup>

<ItemGroup Condition="'$(RuntimeIdentifier)' == '' and $([MSBuild]::IsOSPlatform('OSX'))">
  <Content Include="tools/mac/yt_dlp_mac_universal" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/mac/ffmpeg_mac_universal" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/mac/x64/deno_mac_x64" CopyToOutputDirectory="PreserveNewest" />
  <Content Include="tools/mac/x64/node_mac_x64" CopyToOutputDirectory="PreserveNewest" />
</ItemGroup>


</Project>
